import Mathlib

variable {R : Type*} [CommRing R]

theorem star1_n3_double_even (B c d : R) (V : ℤ → R) (t : ℤ)
    (h1 : V (2*t + 3) = -B*V (t)*V (t + 2)^3 + V (t + 1)^3*V (t + 3))
    (h2 : V (2*t - 3) = B*V (t - 2)^3*V (t) - V (t - 1)^3*V (t - 3))
    (h3 : V (2*t + 1) = B*V (t)^3*V (t + 2) - V (t - 1)*V (t + 1)^3)
    (h4 : V (2*t - 1) = -B*V (t - 2)*V (t)^3 + V (t - 1)^3*V (t + 1))
    (h5 : V (2*t) = V (t - 1)^2*V (t)*V (t + 2) - V (t - 2)*V (t)*V (t + 1)^2)
    (h6 : V (t - 3)*V (t + 3) = -B*V (t)^2*d + V (t - 1)*V (t + 1)*c^2)
    (h7 : V (t - 3)*V (t + 2) = -V (t - 1)*V (t)*d + V (t - 2)*V (t + 1)*c)
    (h8 : V (t - 2)*V (t + 3) = V (t - 1)*V (t + 2)*c - V (t)*V (t + 1)*d)
    (h9 : V (t - 3)*V (t + 1) = B*V (t - 2)*V (t) - V (t - 1)^2*c)
    (h10 : V (t - 2)*V (t + 2) = V (t - 1)*V (t + 1) - V (t)^2*c)
    (h11 : V (t - 1)*V (t + 3) = B*V (t)*V (t + 2) - V (t + 1)^2*c)
    : V (2*t - 3)*V (2*t + 3) = -B*V (2*t)^2*d + V (2*t - 1)*V (2*t + 1)*c^2 := by
  linear_combination (norm := ring1) (V (2*t - 3)) * h1 + (-B*V (t)*V (t + 2)^3 + V (t + 1)^3*V (t + 3)) * h2 + (-V (2*t - 1)*c^2) * h3 + (-B*V (t)^3*V (t + 2)*c^2 + V (t - 1)*V (t + 1)^3*c^2) * h4 + (B*V (2*t)*d + B*V (t - 1)^2*V (t)*V (t + 2)*d - B*V (t - 2)*V (t)*V (t + 1)^2*d) * h5 + (2*B*V (t - 1)^2*V (t)^3*V (t + 2) + 2*B*V (t - 2)*V (t)^3*V (t + 1)^2 - V (t - 1)^3*V (t + 1)^3) * h6 + (-2*B^2*V (t - 1)*V (t)^4*V (t + 2) + B*V (t - 1)^3*V (t)*V (t + 2)^2 - B*V (t - 1)^2*V (t)*V (t + 1)^3) * h7 + (B*V (t - 2)^2*V (t)*V (t + 1)^3 - 2*B*V (t - 3)*V (t)^3*V (t + 1)^2) * h8 + (B*V (t - 1)^2*V (t)*V (t + 1)^2*V (t + 2) + 2*B*V (t)^4*V (t + 1)^2*d) * h9 + (-B^2*V (t - 1)*V (t - 2)*V (t)^2*V (t + 1)*V (t + 2) - B^2*V (t - 2)^2*V (t)^2*V (t + 2)^2 + B^2*V (t - 2)*V (t)^4*V (t + 2)*c + B*V (t - 1)^3*V (t)*V (t + 1)*V (t + 2)*c - 2*B*V (t - 1)^2*V (t)^2*V (t + 1)^2*d + B*V (t - 1)*V (t - 2)*V (t)*V (t + 1)^3*c) * h10 + (-2*B*V (t - 1)*V (t - 3)*V (t)^3*V (t + 2)) * h11


theorem star1_n3_double_odd (B c d : R) (V : ℤ → R) (t : ℤ)
    (h1 : V (2*t + 3) = B*V (t + 1)^3*V (t + 3) - V (t)*V (t + 2)^3)
    (h2 : V (2*t - 3) = -B*V (t - 1)^3*V (t - 3) + V (t - 2)^3*V (t))
    (h3 : V (2*t + 1) = -B*V (t - 1)*V (t + 1)^3 + V (t)^3*V (t + 2))
    (h4 : V (2*t - 1) = B*V (t - 1)^3*V (t + 1) - V (t - 2)*V (t)^3)
    (h5 : V (2*t) = V (t - 1)^2*V (t)*V (t + 2) - V (t - 2)*V (t)*V (t + 1)^2)
    (h6 : V (t - 3)*V (t + 3) = V (t - 1)*V (t + 1)*c^2 - V (t)^2*d)
    (h7 : V (t - 3)*V (t + 2) = -V (t - 1)*V (t)*d + V (t - 2)*V (t + 1)*c)
    (h8 : V (t - 2)*V (t + 3) = V (t - 1)*V (t + 2)*c - V (t)*V (t + 1)*d)
    (h9 : V (t - 3)*V (t + 1) = -V (t - 1)^2*c + V (t - 2)*V (t))
    (h10 : V (t - 2)*V (t + 2) = B*V (t - 1)*V (t + 1) - V (t)^2*c)
    (h11 : V (t - 1)*V (t + 3) = V (t)*V (t + 2) - V (t + 1)^2*c)
    : V (2*t - 3)*V (2*t + 3) = -B*V (2*t)^2*d + V (2*t - 1)*V (2*t + 1)*c^2 := by
  linear_combination (norm := ring1) (V (2*t - 3)) * h1 + (B*V (t + 1)^3*V (t + 3) - V (t)*V (t + 2)^3) * h2 + (-V (2*t - 1)*c^2) * h3 + (B*V (t - 1)*V (t + 1)^3*c^2 - V (t)^3*V (t + 2)*c^2) * h4 + (B*V (2*t)*d + B*V (t - 1)^2*V (t)*V (t + 2)*d - B*V (t - 2)*V (t)*V (t + 1)^2*d) * h5 + (-B^2*V (t - 1)^3*V (t + 1)^3 + 2*B*V (t - 1)^2*V (t)^3*V (t + 2) + 2*B*V (t - 2)*V (t)^3*V (t + 1)^2) * h6 + (-B^2*V (t - 1)^2*V (t)*V (t + 1)^3 + B*V (t - 1)^3*V (t)*V (t + 2)^2 - 2*B*V (t - 1)*V (t)^4*V (t + 2) + V (t - 2)^2*V (t)*V (t + 1)*V (t + 2)^2 + V (t - 2)*V (t)^3*V (t + 1)*V (t + 2)*c) * h7 + (-B^2*V (t - 1)^3*V (t)*V (t + 1)^2 + B*V (t - 2)^2*V (t)*V (t + 1)^3 + B*V (t - 2)*V (t)^4*V (t + 1) - 3*B*V (t - 3)*V (t)^3*V (t + 1)^2) * h8 + (B*V (t - 2)*V (t)^3*V (t + 1)*V (t + 3) + 3*B*V (t)^4*V (t + 1)^2*d) * h9 + (B*V (t - 1)^3*V (t)*V (t + 1)*V (t + 2)*c - B*V (t - 1)^2*V (t - 2)*V (t)*V (t + 1)*V (t + 3) - 3*B*V (t - 1)^2*V (t)^2*V (t + 1)^2*d + B*V (t - 1)*V (t - 2)*V (t)*V (t + 1)^3*c - B*V (t - 1)*V (t - 3)*V (t)*V (t + 1)^2*V (t + 2) - V (t - 1)*V (t - 2)^2*V (t)*V (t + 2)*V (t + 3) - V (t - 1)*V (t - 2)*V (t)^2*V (t + 1)*V (t + 2)*d - V (t - 2)*V (t - 3)*V (t)*V (t + 1)*V (t + 2)^2 + V (t - 2)*V (t)^4*V (t + 2)*c) * h10 + (-2*B*V (t - 1)*V (t - 3)*V (t)^3*V (t + 2) + V (t - 2)^3*V (t)*V (t + 2)^2 + V (t - 2)^2*V (t)^3*V (t + 2)*c) * h11


theorem star3_n3_double_even (B c d : R) (V : ℤ → R) (t : ℤ)
    (h1 : V (2*t + 4) = -V (t)*V (t + 2)*V (t + 3)^2 + V (t + 1)^2*V (t + 2)*V (t + 4))
    (h2 : V (2*t - 3) = B*V (t - 2)^3*V (t) - V (t - 1)^3*V (t - 3))
    (h3 : V (2*t + 2) = -V (t - 1)*V (t + 1)*V (t + 2)^2 + V (t)^2*V (t + 1)*V (t + 3))
    (h4 : V (2*t - 1) = -B*V (t - 2)*V (t)^3 + V (t - 1)^3*V (t + 1))
    (h5 : V (2*t + 1) = B*V (t)^3*V (t + 2) - V (t - 1)*V (t + 1)^3)
    (h6 : V (2*t) = V (t - 1)^2*V (t)*V (t + 2) - V (t - 2)*V (t)*V (t + 1)^2)
    (h7 : V (t - 3)*V (t + 4) = -B*V (t)*V (t + 1)*d + V (t - 1)*V (t + 2)*c*d + V (t)*V (t + 1)*c^3)
    (h8 : V (t - 3)*V (t + 3) = -B*V (t)^2*d + V (t - 1)*V (t + 1)*c^2)
    (h9 : V (t - 2)*V (t + 4) = V (t)*V (t + 2)*c^2 - V (t + 1)^2*d)
    (h10 : V (t - 3)*V (t + 2) = -V (t - 1)*V (t)*d + V (t - 2)*V (t + 1)*c)
    (h11 : V (t - 2)*V (t + 3) = V (t - 1)*V (t + 2)*c - V (t)*V (t + 1)*d)
    (h12 : V (t - 3)*V (t + 1) = B*V (t - 2)*V (t) - V (t - 1)^2*c)
    (h13 : V (t - 2)*V (t + 2) = V (t - 1)*V (t + 1) - V (t)^2*c)
    (h14 : V (t - 1)*V (t + 3) = B*V (t)*V (t + 2) - V (t + 1)^2*c)
    : V (2*t - 3)*V (2*t + 4) = -B*V (2*t)*V (2*t + 1)*d + V (2*t - 1)*V (2*t + 2)*c*d + V (2*t)*V (2*t + 1)*c^3 := by
  linear_combination (norm := ring1) (V (2*t - 3)) * h1 + (-V (t)*V (t + 2)*V (t + 3)^2 + V (t + 1)^2*V (t + 2)*V (t + 4)) * h2 + (-V (2*t - 1)*c*d) * h3 + (V (t - 1)*V (t + 1)*V (t + 2)^2*c*d - V (t)^2*V (t + 1)*V (t + 3)*c*d) * h4 + (B*V (2*t)*d - V (2*t)*c^3) * h5 + (B^2*V (t)^3*V (t + 2)*d - B*V (t - 1)*V (t + 1)^3*d - B*V (t)^3*V (t + 2)*c^3 + V (t - 1)*V (t + 1)^3*c^3) * h6 + (-V (t - 1)^3*V (t + 1)^2*V (t + 2)) * h7 + (-B^2*V (t)^5*V (t + 2) - B*V (t - 1)^2*V (t)^2*V (t + 2)^2 - 2*B*V (t - 1)*V (t)^2*V (t + 1)^3 + 2*B*V (t)^4*V (t + 1)^2*c + V (t - 1)^3*V (t)*V (t + 2)*V (t + 3) + V (t - 1)^2*V (t)*V (t + 1)^2*V (t + 2)*c - V (t - 1)*V (t)^2*V (t + 1)^3*d + V (t - 2)*V (t)*V (t + 1)^4*c) * h8 + (B*V (t - 2)^2*V (t)*V (t + 1)^2*V (t + 2)) * h9 + (B^2*V (t)^5*V (t + 3) + B*V (t - 1)^2*V (t)^2*V (t + 2)*V (t + 3) + B*V (t)^4*V (t + 1)*V (t + 2)*c^2 + B*V (t)^3*V (t + 1)^3*d + V (t - 3)*V (t)*V (t + 1)^3*V (t + 3)) * h10 + (B^2*V (t - 1)*V (t)^3*V (t + 1)^2 - B*V (t - 2)^2*V (t)^2*V (t + 2)*V (t + 3)) * h11 + (B*V (t - 2)*V (t)^2*V (t + 1)*V (t + 2)*V (t + 3) - B*V (t)^4*V (t + 2)^2*c^2 - B*V (t)^3*V (t + 1)^2*V (t + 2)*d - V (t - 3)*V (t)*V (t + 1)^2*V (t + 2)*V (t + 3)) * h12 + (-B^2*V (t - 1)*V (t)^3*V (t + 1)*V (t + 2)*c + B^2*V (t - 2)*V (t)^3*V (t + 1)*V (t + 3) - B^2*V (t)^4*V (t + 1)^2*d - B*V (t - 1)*V (t - 2)*V (t)^2*V (t + 2)*V (t + 3)*c - B*V (t - 1)*V (t)^3*V (t + 1)*V (t + 2)*c*d + 2*B*V (t - 1)*V (t)^2*V (t + 1)^3*c^2 + B*V (t - 2)*V (t)^3*V (t + 1)*V (t + 3)*d + B*V (t - 2)*V (t)^2*V (t + 1)^2*V (t + 2)*c^2 - B*V (t - 2)*V (t)*V (t + 1)^4*d - 2*B*V (t - 3)*V (t)^2*V (t + 1)^2*V (t + 3)) * h13 + (-B^2*V (t)^6*d - 2*B*V (t - 1)^2*V (t)^3*V (t + 2)*d - B*V (t - 1)*V (t - 2)*V (t)^2*V (t + 1)*V (t + 2)*c + B*V (t - 2)*V (t)^4*V (t + 2)*c^2 + B*V (t - 2)*V (t)^3*V (t + 1)^2*d + V (t - 1)^3*V (t)*V (t + 1)*V (t + 2)*c^2 - V (t - 1)^2*V (t)^2*V (t + 1)^2*c*d) * h14


theorem star3_n3_double_odd (B c d : R) (V : ℤ → R) (t : ℤ)
    (h1 : V (2*t + 4) = -V (t)*V (t + 2)*V (t + 3)^2 + V (t + 1)^2*V (t + 2)*V (t + 4))
    (h2 : V (2*t - 3) = -B*V (t - 1)^3*V (t - 3) + V (t - 2)^3*V (t))
    (h3 : V (2*t + 2) = -V (t - 1)*V (t + 1)*V (t + 2)^2 + V (t)^2*V (t + 1)*V (t + 3))
    (h4 : V (2*t - 1) = B*V (t - 1)^3*V (t + 1) - V (t - 2)*V (t)^3)
    (h5 : V (2*t + 1) = -B*V (t - 1)*V (t + 1)^3 + V (t)^3*V (t + 2))
    (h6 : V (2*t) = V (t - 1)^2*V (t)*V (t + 2) - V (t - 2)*V (t)*V (t + 1)^2)
    (h7 : V (t - 3)*V (t + 4) = -B*V (t)*V (t + 1)*d + V (t - 1)*V (t + 2)*c*d + V (t)*V (t + 1)*c^3)
    (h8 : V (t - 3)*V (t + 3) = V (t - 1)*V (t + 1)*c^2 - V (t)^2*d)
    (h9 : V (t - 2)*V (t + 4) = -B*V (t + 1)^2*d + V (t)*V (t + 2)*c^2)
    (h10 : V (t - 3)*V (t + 2) = -V (t - 1)*V (t)*d + V (t - 2)*V (t + 1)*c)
    (h11 : V (t - 2)*V (t + 3) = V (t - 1)*V (t + 2)*c - V (t)*V (t + 1)*d)
    (h12 : V (t - 3)*V (t + 1) = -V (t - 1)^2*c + V (t - 2)*V (t))
    (h13 : V (t - 2)*V (t + 2) = B*V (t - 1)*V (t + 1) - V (t)^2*c)
    (h14 : V (t - 1)*V (t + 3) = V (t)*V (t + 2) - V (t + 1)^2*c)
    : V (2*t - 3)*V (2*t + 4) = -B*V (2*t)*V (2*t + 1)*d + V (2*t - 1)*V (2*t + 2)*c*d + V (2*t)*V (2*t + 1)*c^3 := by
  linear_combination (norm := ring1) (V (2*t - 3)) * h1 + (-V (t)*V (t + 2)*V (t + 3)^2 + V (t + 1)^2*V (t + 2)*V (t + 4)) * h2 + (-V (2*t - 1)*c*d) * h3 + (V (t - 1)*V (t + 1)*V (t + 2)^2*c*d - V (t)^2*V (t + 1)*V (t + 3)*c*d) * h4 + (B*V (2*t)*d - V (2*t)*c^3) * h5 + (-B^2*V (t - 1)*V (t + 1)^3*d + B*V (t - 1)*V (t + 1)^3*c^3 + B*V (t)^3*V (t + 2)*d - V (t)^3*V (t + 2)*c^3) * h6 + (-B*V (t - 1)^3*V (t + 1)^2*V (t + 2)) * h7 + (-2*B^2*V (t - 1)*V (t)^2*V (t + 1)^3 + B*V (t - 1)^3*V (t)*V (t + 2)*V (t + 3) - B*V (t - 1)^2*V (t)^2*V (t + 2)^2 + B*V (t - 1)^2*V (t)*V (t + 1)^2*V (t + 2)*c + B*V (t - 1)*V (t)^4*V (t + 3) - B*V (t - 1)*V (t)^2*V (t + 1)^3*d + B*V (t - 2)*V (t)*V (t + 1)^4*c - 2*B*V (t)^5*V (t + 2) + 3*B*V (t)^4*V (t + 1)^2*c - V (t - 3)*V (t)^3*V (t + 2)*V (t + 3) - 2*V (t)^5*V (t + 2)*d) * h8 + (V (t - 2)^2*V (t)*V (t + 1)^2*V (t + 2)) * h9 + (2*B*V (t - 1)^2*V (t)^2*V (t + 2)*V (t + 3) - B*V (t - 1)*V (t)^3*V (t + 2)^2 + B*V (t - 3)*V (t)*V (t + 1)^3*V (t + 3) + B*V (t)^5*V (t + 3) + B*V (t)^3*V (t + 1)^3*d + V (t - 3)*V (t)^3*V (t + 3)^2 + 2*V (t)^5*V (t + 3)*d) * h10 + (B^2*V (t - 1)*V (t)^3*V (t + 1)^2 + B*V (t - 1)*V (t - 3)*V (t)*V (t + 1)^2*V (t + 3) + 2*B*V (t - 1)*V (t)^3*V (t + 1)^2*d + B*V (t - 2)*V (t)^3*V (t + 1)*V (t + 2) - B*V (t - 3)*V (t)^2*V (t + 1)^2*V (t + 2) + V (t - 1)*V (t)^4*V (t + 2)*c^2 - V (t - 2)^2*V (t)^2*V (t + 2)*V (t + 3) - V (t - 2)*V (t - 3)*V (t)*V (t + 1)*V (t + 2)*V (t + 3) - 2*V (t - 2)*V (t)^3*V (t + 1)*V (t + 2)*d) * h11 + (2*B*V (t - 2)*V (t)^2*V (t + 1)*V (t + 2)*V (t + 3) - B*V (t - 3)*V (t)*V (t + 1)^2*V (t + 2)*V (t + 3)) * h12 + (-B*V (t - 1)*V (t)^3*V (t + 1)*V (t + 2)*c + 2*B*V (t - 1)*V (t)^2*V (t + 1)^3*c^2 + B*V (t - 2)*V (t)^3*V (t + 1)*V (t + 3) - B*V (t - 2)*V (t)*V (t + 1)^4*d - 2*B*V (t - 3)*V (t)^2*V (t + 1)^2*V (t + 3) - B*V (t)^4*V (t + 1)^2*d - V (t - 1)*V (t - 2)*V (t)^2*V (t + 2)*V (t + 3)*c - V (t - 1)*V (t - 3)*V (t)*V (t + 1)*V (t + 2)*V (t + 3)*c - V (t - 1)*V (t)^4*V (t + 3)*c^2 - 3*V (t - 1)*V (t)^3*V (t + 1)*V (t + 2)*c*d + V (t - 2)*V (t - 3)*V (t)*V (t + 1)*V (t + 3)^2 + 3*V (t - 2)*V (t)^3*V (t + 1)*V (t + 3)*d + V (t - 2)*V (t)^2*V (t + 1)^2*V (t + 2)*c^2 + V (t - 3)*V (t)^2*V (t + 1)^2*V (t + 3)*d + V (t)^5*V (t + 2)*c^2 - V (t)^4*V (t + 1)^2*c^3 + 2*V (t)^4*V (t + 1)^2*d^2) * h13 + (B*V (t - 1)^3*V (t)*V (t + 1)*V (t + 2)*c^2 - 3*B*V (t - 1)^2*V (t)^3*V (t + 2)*d - B*V (t - 1)^2*V (t)^2*V (t + 1)^2*c*d - B*V (t - 1)*V (t - 2)*V (t)^2*V (t + 1)*V (t + 2)*c - B*V (t - 1)*V (t - 3)*V (t)^2*V (t + 2)^2 + B*V (t - 2)*V (t)^3*V (t + 1)^2*d - B*V (t - 3)*V (t)^4*V (t + 3) - 2*B*V (t)^6*d + V (t - 2)*V (t)^4*V (t + 2)*c^2 - V (t - 3)*V (t)^4*V (t + 3)*d + V (t)^6*c^3 - 2*V (t)^6*d^2) * h14
