# Copy to .env.local and fill from your Clerk application (Dashboard → API Keys).
# NEVER commit real keys. .env.local is git-ignored.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Where the platform reads the verified truth layer from (the public Pages site).
# Defaults to https://keyai.org if unset. Point it elsewhere for local/staging data.
NEXT_PUBLIC_DATA_BASE=https://keyai.org
