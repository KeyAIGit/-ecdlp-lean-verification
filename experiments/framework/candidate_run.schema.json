{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keyai.example/schemas/ecdlp-candidate-run-v1.json",
  "title": "ECDLP candidate run record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "candidate",
    "target",
    "result",
    "cost",
    "environment",
    "provenance",
    "validation",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "record_kind": {
      "enum": [
        "framework_fixture",
        "candidate_run"
      ]
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "route_id",
        "hypothesis_id",
        "implementation",
        "code_commit",
        "entrypoint"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "route_id": {
          "type": "string",
          "minLength": 1
        },
        "hypothesis_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "implementation": {
          "type": "string",
          "minLength": 1
        },
        "code_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "curve_id",
        "threat_model",
        "field_p",
        "curve_a",
        "curve_b",
        "base_point",
        "target_point",
        "base_order",
        "target_count",
        "auxiliary_inputs",
        "scalar_interval"
      ],
      "properties": {
        "curve_id": {
          "type": "string"
        },
        "threat_model": {
          "type": "string"
        },
        "field_p": {
          "type": "integer"
        },
        "curve_a": {
          "type": "integer"
        },
        "curve_b": {
          "type": "integer"
        },
        "base_point": {
          "$ref": "#/$defs/point"
        },
        "target_point": {
          "$ref": "#/$defs/point"
        },
        "base_order": {
          "type": "integer",
          "minimum": 2
        },
        "target_count": {
          "type": "integer",
          "minimum": 1
        },
        "auxiliary_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scalar_interval": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "array",
              "prefixItems": [
                {
                  "type": "integer"
                },
                {
                  "type": "integer"
                }
              ],
              "items": false
            }
          ]
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claimed_scalar"
      ],
      "properties": {
        "claimed_scalar": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "online",
        "offline",
        "reusable_precomputation",
        "amortization_target_count",
        "parallel_workers",
        "success_probability"
      ],
      "properties": {
        "online": {
          "$ref": "#/$defs/costMetrics"
        },
        "offline": {
          "$ref": "#/$defs/costMetrics"
        },
        "reusable_precomputation": {
          "type": "boolean"
        },
        "amortization_target_count": {
          "type": "integer",
          "minimum": 1
        },
        "parallel_workers": {
          "type": "integer",
          "minimum": 1
        },
        "success_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python",
        "platform",
        "tool_versions"
      ],
      "properties": {
        "python": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "tool_versions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seed",
        "command",
        "dirty_worktree",
        "input_sha256",
        "output_sha256",
        "environment_sha256",
        "record_sha256"
      ],
      "properties": {
        "seed": {
          "type": "integer"
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dirty_worktree": {
          "const": false
        },
        "input_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "output_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "environment_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "record_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "independent_implementation",
        "shares_decisive_logic",
        "passed",
        "validator_output_sha256"
      ],
      "properties": {
        "validator_id": {
          "const": "framework.ec_oracle.v1"
        },
        "independent_implementation": {
          "const": true
        },
        "shares_decisive_logic": {
          "const": false
        },
        "passed": {
          "type": "boolean"
        },
        "validator_output_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "success_level",
        "asymptotic_claim",
        "secp256k1_break",
        "disclosure_gate_acknowledged"
      ],
      "properties": {
        "success_level": {
          "enum": [
            "scope-only",
            "constant-factor",
            "subgeneric",
            "practical-secp256k1"
          ]
        },
        "asymptotic_claim": {
          "type": [
            "string",
            "null"
          ]
        },
        "secp256k1_break": {
          "type": "boolean"
        },
        "disclosure_gate_acknowledged": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "point": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "array",
          "prefixItems": [
            {
              "type": "integer"
            },
            {
              "type": "integer"
            }
          ],
          "items": false
        }
      ]
    },
    "costMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_time_seconds",
        "group_operations",
        "field_operations",
        "peak_memory_bytes"
      ],
      "properties": {
        "wall_time_seconds": {
          "type": "number",
          "minimum": 0
        },
        "group_operations": {
          "type": "integer",
          "minimum": 0
        },
        "field_operations": {
          "type": "integer",
          "minimum": 0
        },
        "peak_memory_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
