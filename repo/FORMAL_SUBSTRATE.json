  "blockers": [
    {
      "id": "blocker-point-division-map",
      "kind": "upstream-foundation",
      "title": "No uniform Point-to-division-polynomial multiplication map",
      "description": "Mathlib exposes the polynomial identities but not the theorem connecting [n]P to the phi/psi coordinate formulas for all n.",
      "evidence_files": [
        "BARRIERS.md",
        "notes/UPSTREAM_SCAN.md",
        "Ecdlp/Targets/n7_uniform_carrier_induction.lean"
      ],
      "resume_condition": "An upstream multiplication-coordinate theorem lands, or a reviewed in-repo induction closes the torsion bridge."
    },
    {
      "id": "blocker-n7-certificates",
      "kind": "proof-engineering",
      "title": "Four N7 algebra walls need large checked elimination certificates",
      "description": "The statements are machine-elaborated and numerically/symbolically validated, but checked cofactors for the degree-heavy identities are not yet authored.",
      "evidence_files": [
        "notes/N7_EVEN_X_DOUBLING_ANALYSIS.md",
        "Ecdlp/Targets/n7_uniform_carrier_induction.lean"
      ],
      "resume_condition": "A reproducible certificate generator emits Lean-checkable cofactors for all four algebra walls."
    },
    {
      "id": "blocker-uniform-separability",
      "kind": "missing-theory",
      "title": "Uniform separability of multiplication-by-n is not available",
      "description": "Small n is closed, while the general prime-to-characteristic counting and differential argument remains absent.",
      "evidence_files": [
        "BARRIERS.md",
        "notes/SEPARABILITY_ROUTES.md"
      ],
      "resume_condition": "A checked [n]*omega=n omega or equivalent general separability theorem is available."
    },
    {
      "id": "blocker-weil-reciprocity",
      "kind": "upstream-foundation",
      "title": "Weil reciprocity and divisor-degree machinery are missing",
      "description": "The reachable W1-W3 evaluation substrate is closed; W4 reciprocity is required before the pairing can be assembled.",
      "evidence_files": [
        "BARRIERS.md",
        "notes/WEIL_LADDER.md",
        "notes/FOUNDATIONS.md"
      ],
      "resume_condition": "Mathlib or this repository gains the needed divisor/tame-symbol reciprocity layer."
    },
    {
      "id": "blocker-p256-cardinality",
      "kind": "out-of-scope-foundation",
      "title": "P-256 exact cardinality needs a general point-counting/Hasse route",
      "description": "Only n divides the P-256 group cardinality is proved; the secp256k1 j=0 certificate does not transfer.",
      "evidence_files": [
        "notes/POINT_COUNTING_KEYSTONE.md",
        "BARRIERS.md"
      ],
      "resume_condition": "A reviewed Hasse/Schoof or curve-specific exact-cardinality proof becomes available."
    }
  ],
