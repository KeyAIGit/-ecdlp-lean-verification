import Mathlib

/-!
# The n-torsion subgroup `E[n]` ‚Äî bridge to Mathlib and to the discrete-log model

`notes/FOUNDATIONS.md` lists "`n`-torsion subgroup `E[n]` as a group object" as the
first deep-foundations rung toward the Weil pairing. Mathlib already provides it:
`AddSubgroup.torsionBy A n` (notation `A[n]`) is the subgroup `{x | n ‚Ä¢ x = 0}` of any
`AddCommGroup`, with a `Module (ZMod n)` structure (`torsionBy.zmodModule`). So `E[n]`
is *available* for the secp256k1 point group `WeierstrassCurve.Affine.Point` for free.

This file records the genuinely-new connective tissue that the bare definition does not
give:

* `mem_torsionBy_iff_addOrderOf_dvd` ‚Äî the order characterization: a point lies in `E[n]`
  iff its order divides `n`. This is the abstract content of "`[n]P = O ‚ü∫ ord(P) ‚à£ n`"
  and the reason `‚ü®G‚ü© ‚äÜ E[n]` whenever `ord(G) ‚à£ n`.
* `torsionBy_dvd_le` ‚Äî the torsion filtration `E[m] ‚â§ E[n]` for `m ‚à£ n` (so `E[m]` grows
  monotonically along divisibility, e.g. `E[2] ‚äÜ E[2k]`).
* `zmod_module_nsmul_eq_zero` / `torsionBy_eq_top` ‚Äî the bridge to the discrete-log model
  used throughout `DlogCompleteness.lean`/`DlogPrimitives.lean`: a `ZMod n`-module is its
  own `n`-torsion (`G[n] = ‚ä§`), i.e. the whole DL group is `n`-torsion. For secp256k1
  (cofactor 1) this is the abstract shape of "every curve point has order dividing `n`".

All of this is general `AddCommGroup` / `Module (ZMod n)` algebra ‚Äî kernel-checked, no
new axioms ‚Äî and applies verbatim to the elliptic-curve point group.
-/

namespace Ecdlp.Torsion

/-! ## Order characterization and the torsion filtration (any `AddCommGroup`) -/

variable {A : Type*} [AddCommGroup A]

/-- **`E[n]` is exactly the points of order dividing `n`.** A point lies in the
`n`-torsion subgroup iff its additive order divides `n`. This is the abstract form of
`[n]P = O ‚ü∫ ord(P) ‚à£ n`; in particular the cyclic group `‚ü®G‚ü©` generated by a point of
order `n` lies inside `E[n]`. -/
theorem mem_torsionBy_iff_addOrderOf_dvd {n : ‚Ñï} (x : A) :
    x ‚àà AddSubgroup.torsionBy A (n : ‚Ñ§) ‚Üî addOrderOf x ‚à£ n := by
  rw [AddSubgroup.torsionBy.nsmul_iff, ‚Üê addOrderOf_dvd_iff_nsmul_eq_zero]

/-- **The base-point subgroup lies in the torsion: `‚ü®g‚ü© ‚â§ E[n]` when `ord(g) ‚à£ n`.**
The cyclic subgroup generated by a point whose order divides `n` is contained in the
`n`-torsion. This is the abstract form of `‚ü®G‚ü© ‚äÜ E[n]` for the ECDLP base point: the
prime-order-`n` subgroup that secp256k1 cryptography operates in is part of the
`n`-torsion `E[n]`. -/
theorem zmultiples_le_torsionBy {n : ‚Ñï} {g : A} (h : addOrderOf g ‚à£ n) :
    AddSubgroup.zmultiples g ‚â§ AddSubgroup.torsionBy A (n : ‚Ñ§) := by
  rw [AddSubgroup.zmultiples_le, mem_torsionBy_iff_addOrderOf_dvd]
  exact h

/-- **The torsion filtration: `E[m] ‚â§ E[n]` when `m ‚à£ n`.** Torsion subgroups grow
monotonically along divisibility ‚Äî every `m`-torsion point is `n`-torsion when `m ‚à£ n`
(so e.g. `E[2] ‚äÜ E[6]`). The building block for reasoning about the lattice of torsion
subgroups. -/
theorem torsionBy_dvd_le {m k : ‚Ñ§} (h : m ‚à£ k) :
    AddSubgroup.torsionBy A m ‚â§ AddSubgroup.torsionBy A k :=
  Submodule.toAddSubgroup_mono (Submodule.torsionBy_le_torsionBy_of_dvd m k h)

/-! ## Bridge to the discrete-log model: a `ZMod n`-module is its own `n`-torsion -/

variable {n : ‚Ñï} [Module (ZMod n) A]

/-- **A `ZMod n`-module is killed by `n`.** Every element of the discrete-log group
(modelled as a `ZMod n`-module, exponent dividing `n`) satisfies `n ‚Ä¢ x = 0`: scalar `n`
acts as `0` because `(n : ZMod n) = 0`. -/
theorem zmod_module_nsmul_eq_zero (x : A) : n ‚Ä¢ x = 0 := by
  rw [‚Üê Nat.cast_smul_eq_nsmul (R := ZMod n) n x, ZMod.natCast_self, zero_smul]

/-- **The whole DL group is its `n`-torsion: `G[n] = ‚ä§`.** The cyclic group used to model
discrete-log cryptography (`Module (ZMod n) G`) coincides with its own `n`-torsion
subgroup. For secp256k1, whose cofactor is `1`, this is the abstract shape of "every curve
point has order dividing `n`" ‚Äî `E(ùîΩ‚Çö) = E[n]`. -/
theorem torsionBy_eq_top : AddSubgroup.torsionBy A (n : ‚Ñ§) = ‚ä§ := by
  rw [eq_top_iff]
  intro x _
  rw [AddSubgroup.torsionBy.nsmul_iff]
  exact zmod_module_nsmul_eq_zero x

end Ecdlp.Torsion
