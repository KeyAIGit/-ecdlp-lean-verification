import Ecdlp.Proved.ProtocolInstantiation

/-!
# The discrete-log group structure of secp256k1's subgroup `‚ü®G‚ü©`

`ProtocolInstantiation.lean` realises the abstract `ZMod n`-module model on the concrete
cyclic subgroup `‚ü®G‚ü© = zmultiples secp256k1G`. This file records the *structure* of that
group: it has exactly `n` elements, is cyclic, and ‚Äî the precise statement underlying the
elliptic-curve discrete-log problem ‚Äî the base-point-multiplication map `c ‚Ü¶ c¬∑G` is a
**group isomorphism** `ZMod n ‚âÉ+ ‚ü®G‚ü©`.

Everything rests on the weak point-counting keystone `addOrderOf secp256k1G = n`
(`GeneratorOrder.lean`); no Hasse / `#E` is used. The isomorphism says exactly that the
discrete log is a well-defined bijection `‚ü®G‚ü© ‚Üí ZMod n` ‚Äî its *hardness* is the open ECDLP
conjecture, of which this states only the (unconditional) group-theoretic shape.
-/

open WeierstrassCurve.Affine

namespace Ecdlp.Curve

/-- **`‚ü®G‚ü©` has exactly `n` elements.** The concrete secp256k1 crypto subgroup is finite of
cardinality `n`, from `Nat.card (zmultiples g) = addOrderOf g` and `addOrderOf G = n`. -/
theorem secp256k1_grp_card : Nat.card ‚Ü•secp256k1Grp = Secp256k1.n := by
  rw [Nat.card_zmultiples, secp256k1_generator_addOrderOf]

/-- **`‚ü®G‚ü©` is a cyclic additive group** (generated by the single base point). -/
theorem secp256k1_grp_isAddCyclic : IsAddCyclic ‚Ü•secp256k1Grp := inferInstance

/-- The base point `G`, viewed inside its own subgroup `‚ü®G‚ü©`, has additive order `n`. -/
theorem secp256k1_gen_addOrderOf : addOrderOf secp256k1G‚Çô = Secp256k1.n := by
  have h : addOrderOf (secp256k1Grp.subtype secp256k1G‚Çô) = addOrderOf secp256k1G‚Çô :=
    addOrderOf_injective secp256k1Grp.subtype Subtype.coe_injective secp256k1G‚Çô
  rw [‚Üê h]; exact secp256k1_generator_addOrderOf

/-- The discrete-log map `c ‚Ü¶ c¬∑G` as an additive homomorphism `ZMod n ‚Üí+ ‚ü®G‚ü©`. -/
noncomputable def secp256k1_dlogHom : ZMod Secp256k1.n ‚Üí+ ‚Ü•secp256k1Grp :=
  (smulAddHom (ZMod Secp256k1.n) ‚Ü•secp256k1Grp).flip secp256k1G‚Çô

@[simp] theorem secp256k1_dlogHom_apply (c : ZMod Secp256k1.n) :
    secp256k1_dlogHom c = c ‚Ä¢ secp256k1G‚Çô := rfl

/-- The discrete-log map is injective: distinct scalars give distinct points (via
`addOrderOf G = n` and `c.val < n`). -/
theorem secp256k1_dlogHom_injective : Function.Injective secp256k1_dlogHom := by
  rw [injective_iff_map_eq_zero]
  intro c hc
  rw [secp256k1_dlogHom_apply] at hc
  have h0 : (c.val : ‚Ñï) ‚Ä¢ secp256k1G‚Çô = 0 := by
    rw [‚Üê Nat.cast_smul_eq_nsmul (R := ZMod Secp256k1.n), ZMod.natCast_rightInverse c]
    exact hc
  have hdvd : addOrderOf secp256k1G‚Çô ‚à£ c.val := addOrderOf_dvd_of_nsmul_eq_zero h0
  rw [secp256k1_gen_addOrderOf] at hdvd
  exact (ZMod.val_eq_zero c).mp (Nat.eq_zero_of_dvd_of_lt hdvd (ZMod.val_lt c))

/-- The discrete-log map is surjective: every point of `‚ü®G‚ü©` is `c¬∑G` for some scalar. -/
theorem secp256k1_dlogHom_surjective : Function.Surjective secp256k1_dlogHom := by
  intro y
  obtain ‚ü®k, hk‚ü© := AddSubgroup.mem_zmultiples_iff.mp y.2
  refine ‚ü®(k : ZMod Secp256k1.n), ?_‚ü©
  rw [secp256k1_dlogHom_apply, Int.cast_smul_eq_zsmul]
  apply Subtype.ext
  rw [AddSubgroup.coe_zsmul]
  exact hk

/-- **The discrete-log map is a group isomorphism `ZMod n ‚âÉ+ ‚ü®G‚ü©`.** The base-point
multiplication `c ‚Ü¶ c¬∑G` is an additive-group isomorphism between the scalar ring `ZMod n`
and the concrete secp256k1 subgroup `‚ü®G‚ü©`. This is the exact group-theoretic content of the
elliptic-curve discrete-log setting: `dlog = (c ‚Ü¶ c¬∑G)‚Åª¬π` is a well-defined bijection.
Its *computational* inversion is the open ECDLP hardness conjecture; this theorem asserts
only the unconditional bijection, from `addOrderOf G = n`. -/
noncomputable def secp256k1_dlogEquiv : ZMod Secp256k1.n ‚âÉ+ ‚Ü•secp256k1Grp :=
  AddEquiv.ofBijective secp256k1_dlogHom
    ‚ü®secp256k1_dlogHom_injective, secp256k1_dlogHom_surjective‚ü©

@[simp] theorem secp256k1_dlogEquiv_apply (c : ZMod Secp256k1.n) :
    secp256k1_dlogEquiv c = c ‚Ä¢ secp256k1G‚Çô := rfl

end Ecdlp.Curve
