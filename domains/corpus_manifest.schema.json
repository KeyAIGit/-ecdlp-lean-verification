{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://keyai.org/schemas/corpus-manifest-v1.json",
  "title": "KeyAI research corpus manifest",
  "description": "Domain-agnostic, append-only snapshot and delta contract for source integrity, version relations, threat models, review state, and decision impact.",
  "type": "object",
  "required": [
    "schema_version",
    "manifest_id",
    "domain_id",
    "as_of",
    "target",
    "policy",
    "baseline_snapshot",
    "delta_snapshots",
    "effective_counts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "domain_id": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "purpose": {
      "type": "string"
    },
    "target": {
      "type": "object"
    },
    "source_systems": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "policy": {
      "type": "object"
    },
    "controlled_vocabularies": {
      "type": "object"
    },
    "baseline_snapshot": {
      "type": "object",
      "required": [
        "id",
        "date",
        "source_count",
        "source_ids",
        "artifacts"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "source_count": {
          "type": "integer",
          "minimum": 1
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "delta_snapshots": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "effective_counts": {
      "type": "object"
    }
  }
}
